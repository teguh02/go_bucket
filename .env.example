# Required - API key for upload/delete operations
STORAGE_API_KEY=change-me

# Server port (default: 8080)
PORT=8080

# Storage directory inside container (default: /data)
# This is mounted from ./storage on the host
STORAGE_DIR=/data

# Public base URL for generating file URLs (optional)
# If empty, URL is built from request host
PUBLIC_BASE_URL=http://localhost:8080

# Maximum upload size in MB (default: 50)
MAX_UPLOAD_MB=50

# Allow overwriting existing files (default: false for safety)
ALLOW_OVERWRITE=false

# Allow deleting files via API (default: true)
# Set to false to disable all file deletions even with a valid API key
ALLOW_DELETE=true

# CORS allowed origins (default: *)
# Use comma-separated list for multiple origins: http://localhost:3000,https://myapp.com
CORS_ALLOWED_ORIGINS=*

# Cache-Control max-age in seconds (default: 31536000 = 1 year)
CACHE_MAX_AGE=31536000
