{
	"info": {
		"_postman_id": "cdn-storage-server",
		"name": "CDN Storage Server",
		"description": "Simple CDN Storage Server API - A lightweight file storage server similar to S3/GCS",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "api_key",
			"value": "change-me",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Health Check",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/health",
					"host": ["{{base_url}}"],
					"path": ["health"]
				},
				"description": "Check server health status"
			},
			"response": []
		},
		{
			"name": "Upload File (Multipart)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "X-API-Key",
						"value": "{{api_key}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "file",
							"type": "file",
							"src": "",
							"description": "File to upload (required)"
						},
						{
							"key": "path",
							"value": "images/example.png",
							"type": "text",
							"description": "Destination path (optional, defaults to original filename)"
						}
					]
				},
				"url": {
					"raw": "{{base_url}}/api/upload",
					"host": ["{{base_url}}"],
					"path": ["api", "upload"]
				},
				"description": "Upload a file using multipart/form-data.\n\n**Auth Required**: X-API-Key or Authorization: Bearer\n\n**Form Fields**:\n- `file` (required): The file to upload\n- `path` (optional): Destination path, e.g., `avatars/user1.jpg`\n\n**Response includes** `hash.md5` and `hash.sha1` for integrity checking."
			},
			"response": []
		},
		{
			"name": "Upload File (Bearer Auth)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{api_key}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "file",
							"type": "file",
							"src": "",
							"description": "File to upload (required)"
						},
						{
							"key": "path",
							"value": "documents/report.pdf",
							"type": "text",
							"description": "Destination path"
						}
					]
				},
				"url": {
					"raw": "{{base_url}}/api/upload",
					"host": ["{{base_url}}"],
					"path": ["api", "upload"]
				},
				"description": "Upload a file using Bearer token authentication"
			},
			"response": []
		},
		{
			"name": "Upload File (URL)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "X-API-Key",
						"value": "{{api_key}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "file",
							"value": "https://placehold.co/600x400.png",
							"type": "text",
							"description": "Remote URL — server will download and store the file"
						},
						{
							"key": "path",
							"value": "images/placeholder.png",
							"type": "text",
							"description": "Destination path (optional, defaults to filename from URL)"
						}
					]
				},
				"url": {
					"raw": "{{base_url}}/api/upload",
					"host": ["{{base_url}}"],
					"path": ["api", "upload"]
				},
				"description": "Upload a file by supplying a remote URL as the `file` field. The server fetches and stores the file.\n\nSupports any publicly accessible URL pointing to a file (image, PDF, audio, video, etc.)."
			},
			"response": []
		},
		{
			"name": "Upload File (Base64)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "X-API-Key",
						"value": "{{api_key}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "file",
							"value": "data:text/plain;base64,SGVsbG8gV29ybGQh",
							"type": "text",
							"description": "Base64-encoded file content (plain base64 or data URI)"
						},
						{
							"key": "path",
							"value": "files/hello.txt",
							"type": "text",
							"description": "Destination path (optional)"
						}
					]
				},
				"url": {
					"raw": "{{base_url}}/api/upload",
					"host": ["{{base_url}}"],
					"path": ["api", "upload"]
				},
				"description": "Upload a file using base64-encoded content.\n\nThe `file` field accepts:\n- Plain base64: `SGVsbG8gV29ybGQh`\n- Data URI: `data:text/plain;base64,SGVsbG8gV29ybGQh`"
			},
			"response": []
		},
		{
			"name": "Upload File (Binary Body)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "X-API-Key",
						"value": "{{api_key}}",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/octet-stream",
						"type": "text"
					}
				],
				"body": {
					"mode": "file",
					"file": {
						"src": ""
					}
				},
				"url": {
					"raw": "{{base_url}}/api/upload?path=binary/file.bin",
					"host": ["{{base_url}}"],
					"path": ["api", "upload"],
					"query": [
						{
							"key": "path",
							"value": "binary/file.bin",
							"description": "Destination path (required for binary uploads)"
						}
					]
				},
				"description": "Upload a file by sending raw binary bytes as the request body.\n\nUseful for Ajax / axios / jQuery XHR uploads from the browser.\n\nThe destination path must be provided via:\n- `?path=` query parameter, OR\n- `X-File-Path` request header"
			},
			"response": []
		},
		{
			"name": "Upload File (JSON - URL)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "X-API-Key",
						"value": "{{api_key}}",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"file\": \"https://placehold.co/600x400.png\",\n  \"path\": \"images/placeholder.png\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/api/upload",
					"host": ["{{base_url}}"],
					"path": ["api", "upload"]
				},
				"description": "Upload a file via JSON body.\n\nThe `file` field accepts a remote URL or base64-encoded data.\nThe `path` field sets the destination path."
			},
			"response": []
		},
		{
			"name": "Upload File (JSON - Base64)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "X-API-Key",
						"value": "{{api_key}}",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"file\": \"SGVsbG8gV29ybGQh\",\n  \"path\": \"files/hello.txt\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/api/upload",
					"host": ["{{base_url}}"],
					"path": ["api", "upload"]
				},
				"description": "Upload a file via JSON body with base64-encoded content."
			},
			"response": []
		},
		{
			"name": "Get File (Public)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/files/images/example.png",
					"host": ["{{base_url}}"],
					"path": ["files", "images", "example.png"]
				},
				"description": "Access a file publicly (no auth required).\n\nChange the path to match your uploaded file."
			},
			"response": []
		},
		{
			"name": "List Files",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "X-API-Key",
						"value": "{{api_key}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/list",
					"host": ["{{base_url}}"],
					"path": ["api", "list"]
				},
				"description": "List all files in the storage (page 1, 10 per page by default).\n\nEach file entry includes `hash.md5` and `hash.sha1` for integrity checking.\n\nResponse includes pagination metadata: `page`, `per_page`, `total`, `total_pages`."
			},
			"response": []
		},
		{
			"name": "List Files (Page 2)",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "X-API-Key",
						"value": "{{api_key}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/list?page=2&per_page=10",
					"host": ["{{base_url}}"],
					"path": ["api", "list"],
					"query": [
						{
							"key": "page",
							"value": "2",
							"description": "Page number (default: 1)"
						},
						{
							"key": "per_page",
							"value": "10",
							"description": "Results per page (default: 10)"
						}
					]
				},
				"description": "List files with explicit pagination parameters."
			},
			"response": []
		},
		{
			"name": "List Files with Prefix",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "X-API-Key",
						"value": "{{api_key}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/list?prefix=images",
					"host": ["{{base_url}}"],
					"path": ["api", "list"],
					"query": [
						{
							"key": "prefix",
							"value": "images",
							"description": "Filter files by prefix/folder"
						}
					]
				},
				"description": "List files with a specific prefix (folder)"
			},
			"response": []
		},
		{
			"name": "Delete File",
			"request": {
				"method": "DELETE",
				"header": [
					{
						"key": "X-API-Key",
						"value": "{{api_key}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/files/images/example.png",
					"host": ["{{base_url}}"],
					"path": ["api", "files", "images", "example.png"]
				},
				"description": "Delete a file from storage.\n\n**Auth Required**: X-API-Key or Authorization: Bearer\n\n**Note**: Deletion can be disabled server-side via `ALLOW_DELETE=false`. In that case this endpoint returns HTTP 403 regardless of API key validity.\n\nChange the path to match the file you want to delete."
			},
			"response": []
		},
		{
			"name": "Delete File (Bearer Auth)",
			"request": {
				"method": "DELETE",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{api_key}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/files/documents/report.pdf",
					"host": ["{{base_url}}"],
					"path": ["api", "files", "documents", "report.pdf"]
				},
				"description": "Delete a file using Bearer token authentication"
			},
			"response": []
		}
	]
}

